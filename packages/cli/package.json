{
  "name": "@intentsolutions/jrig-cli",
  "version": "0.2.0",
  "private": false,
  "description": "J-Rig seven-layer binary eval CLI for Claude Skills — the `j-rig` command: package-integrity, trigger, functional, rollout-safety, and cost scoring by default (the regression + baseline layers are coded and opt-in; each run declares its coverage), plus optimizer and rollout-gate evidence. Self-contained (bundles the internal eval engine).",
  "keywords": [
    "j-rig",
    "jrig",
    "intent-eval",
    "eval",
    "skill",
    "claude",
    "claude-code",
    "cli",
    "skill-eval"
  ],
  "homepage": "https://github.com/jeremylongshore/j-rig-skill-binary-eval/tree/main/packages/cli",
  "bugs": "https://github.com/jeremylongshore/j-rig-skill-binary-eval/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/j-rig-skill-binary-eval.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "author": "Jeremy Longshore <jeremy@intentsolutions.io>",
  "type": "module",
  "bin": {
    "j-rig": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@intentsolutions/core": "0.10.0",
    "@intentsolutions/refiner": "workspace:^",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.4.0",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@j-rig/core": "workspace:*",
    "@j-rig/db": "workspace:*",
    "@j-rig/migrate": "workspace:*"
  }
}
