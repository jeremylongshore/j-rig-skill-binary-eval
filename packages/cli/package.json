{
  "name": "@j-rig/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "j-rig": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@j-rig/core": "workspace:*",
    "@j-rig/db": "workspace:*",
    "commander": "^14.0.3",
    "chalk": "^5.4.0"
  }
}
