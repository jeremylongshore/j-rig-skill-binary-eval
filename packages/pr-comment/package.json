{
  "name": "@j-rig/pr-comment",
  "version": "2.1.0",
  "private": false,
  "description": "Pure, idempotent renderer that turns a rollout-gate decision into a marker-anchored markdown PR comment block",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/j-rig-skill-binary-eval.git",
    "directory": "packages/pr-comment"
  },
  "author": "Jeremy Longshore <jeremy@jeremylongshore.com>",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@intentsolutions/rollout-gate": "workspace:*"
  }
}
