{
  "name": "@j-rig/migrate",
  "version": "2.1.0",
  "private": false,
  "description": "Codemod that rewrites v0.1.0-draft Evidence Bundle rows into the v2.0 gate-result/v1 shape and emits a unified diff",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/j-rig-skill-binary-eval.git",
    "directory": "packages/migrate"
  },
  "author": "Jeremy Longshore <jeremy@jeremylongshore.com>",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@j-rig/core": "workspace:*"
  }
}
