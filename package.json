{
  "name": "j-rig-binary-eval",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Seven-layer binary evaluation harness and rollout gate for Claude Skills",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tests/tsconfig.json && pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "test:coverage": "vitest run --coverage",
    "lint:md": "markdownlint-cli2",
    "emit:evidence": "node --experimental-strip-types scripts/emit-evidence.ts",
    "assemble:manifest": "node --experimental-strip-types scripts/assemble-manifest.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@intentsolutions/core": "0.2.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^10.4.1",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.1.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/j-rig-binary-eval.git"
  },
  "author": "Jeremy Longshore <jeremy@jeremylongshore.com>",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
