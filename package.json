{
  "name": "j-rig-binary-eval",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Seven-layer binary evaluation harness and rollout gate for Claude Skills",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tests/tsconfig.json && pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:refiner-core": "vitest run --coverage --config packages/refiner-core/vitest.config.ts",
    "lint:md": "markdownlint-cli2",
    "emit:evidence": "node --experimental-strip-types scripts/emit-evidence.ts",
    "assemble:manifest": "node --experimental-strip-types scripts/assemble-manifest.ts",
    "license:audit": "node --experimental-strip-types scripts/license-audit.ts --prod",
    "harness:verify": "scripts/audit-harness verify",
    "harness:init": "scripts/audit-harness init"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@intentsolutions/core": "0.9.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.1.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/j-rig-binary-eval.git"
  },
  "author": "Jeremy Longshore <jeremy@jeremylongshore.com>",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
