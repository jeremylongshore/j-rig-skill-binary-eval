// markdownlint-cli2 config for j-rig-binary-eval
{
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD033": false,
    "MD041": false,
    "MD007": { "indent": 2 }
  },
  "globs": ["**/*.md"],
  "ignores": [
    "**/node_modules/**",
    "packages/*/dist/**",
    ".audit-harness/**"
  ]
}
